# --- Supabase --------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...
SUPABASE_SERVICE_ROLE_KEY=ey...

# Server-only URL (same value as NEXT_PUBLIC_SUPABASE_URL — keeps it out of the client bundle)
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Connection pooler — Transaction Mode, port 6543 (for serverless/Next.js on Vercel)
# Get from: Supabase Dashboard → Project Settings → Database → Connection Pooling
# Format: postgresql://postgres.[project-ref]:[db-password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=

# --- Public site URL (used by sitemap, OG tags, share links, redirects) ----
# In production, set this to your live origin, e.g. https://medialinkpro.com
NEXT_PUBLIC_SITE_URL=https://medialinkpro.net
NEXT_PUBLIC_APP_URL=https://medialinkpro.net

# --- Email (Resend) --------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=hello@medialinkpro.net

# --- Stripe (billing) ------------------------------------------------------
# Use your real test/live keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET

# Stripe Price IDs — one per (plan × billing interval).
# Create these in the Stripe dashboard, then paste the price_xxx IDs below.
NEXT_PUBLIC_STRIPE_PRICE_INDIVIDUAL_PRO_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_INDIVIDUAL_PRO_ANNUAL=
NEXT_PUBLIC_STRIPE_PRICE_ORG_STARTER_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_ORG_STARTER_ANNUAL=
NEXT_PUBLIC_STRIPE_PRICE_ORG_GROWTH_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_ORG_GROWTH_ANNUAL=
NEXT_PUBLIC_STRIPE_PRICE_ORG_ENTERPRISE_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_ORG_ENTERPRISE_ANNUAL=

# --- Optional: feature flags ----------------------------------------------
# NODE_ENV=production
